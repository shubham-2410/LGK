# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/localgoa_db

# ── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
SESSION_SECRET=change-me-to-a-long-random-string

# ── CORS (comma-separated list of allowed frontend origins) ─────────────────
# Development: leave as localhost
# Production on VPS: set to your cPanel domain e.g. https://lgk.com,https://www.lgk.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5000

# ── PhonePe Payments ────────────────────────────────────────────────────────
PHONEPE_MERCHANT_ID=
PHONEPE_SALT_KEY=
PHONEPE_SALT_INDEX=1
PHONEPE_ENV=sandbox

# ── Google Drive uploads (optional) ─────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# ── Email (optional) ────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
